# Example jail — copy to /etc/fail2ban/jail.d/plainlist-auth.local
# and set logpath to your absolute auth-audit.log path.

[plainlist-auth]
enabled  = true
filter   = plainlist-auth
# Repo default log file (override with your deploy path):
logpath  = /path/to/trae-plainlist/logs/auth-audit.log
backend  = auto
maxretry = 5
findtime = 10m
bantime  = 1h
# If API is only reached via Nginx on 80/443, ban on those ports:
port     = http,https
# For direct Node exposure on 3000 instead:
# port     = 3000
