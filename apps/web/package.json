{
  "name": "@plainlist/web",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run build -w @plainlist/shared",
    "dev": "vite",
    "prebuild": "npm run build -w @plainlist/shared",
    "build": "vue-tsc -p tsconfig.json && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.vue",
    "test": "vitest run src",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@plainlist/shared": "*",
    "echarts": "^6.0.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.29"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.4",
    "vite": "^7.3.1",
    "vue-tsc": "^3.1.1"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
