{
  "name": "@plainlist/web",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run build -w @plainlist/shared",
    "dev": "vite",
    "prebuild": "npm run build -w @plainlist/shared",
    "build": "vue-tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.vue",
    "test": "vitest run src",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios",
    "mobile:build": "npm run build && npx cap sync",
    "mobile:android": "npm run mobile:build && npx cap open android",
    "mobile:ios": "npm run mobile:build && npx cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@plainlist/shared": "*",
    "echarts": "^6.0.0",
    "matter-js": "^0.20.0",
    "pinia": "^3.0.4",
    "three": "^0.160.1",
    "vue": "^3.5.29"
  },
  "devDependencies": {
    "@types/matter-js": "^0.20.2",
    "@types/three": "^0.160.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "vite": "^7.3.1",
    "vue-tsc": "^3.1.1"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
