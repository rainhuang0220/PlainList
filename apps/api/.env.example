DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
# 本机 MySQL 默认端口 3306；root 密码按你机器实际填写
DB_PASS=root
DB_NAME=plainlist
JWT_SECRET=change-me-in-production

# ── AI 默认配置（可选）────────────────────────────────────
# 用户可在工作台导航栏「AI」填个人 Key（BYOK，优先于此处）。
# 仅当用户未配置个人 Key 时，才使用下面这组服务端默认值。

AI_PROVIDER=openai
AI_REVIEW_BASE_URL=https://api.siliconflow.cn/v1
AI_REVIEW_MODEL=deepseek-ai/DeepSeek-V3.1-Terminus
AI_REVIEW_API_KEY=
# 可选：AI 速记专用更快模型；留空则与 AI_REVIEW_MODEL 相同
# AI_INTAKE_MODEL=deepseek-ai/DeepSeek-V3.1-Terminus
AI_REVIEW_TIMEOUT_MS=30000
AI_ANTHROPIC_VERSION=2023-06-01

# ── 新用户 AI 速记默认 Key（预置到 user_settings.ai_settings）───
# 服务端配置后，新注册用户与 seed 出的 demo 用户都会自动带上这套配置，
# 评委无需手动填写 API Key。Key 只存在服务端 .env 与数据库，不入 git。
#
# 留空 = 不预置，走上面 AI_REVIEW_API_KEY 服务端兜底（已有逻辑）。
AI_USER_DEFAULT_API_KEY=
AI_USER_DEFAULT_BASE_URL=
AI_USER_DEFAULT_MODEL=
AI_USER_DEFAULT_INTAKE_MODEL=
AI_USER_DEFAULT_PROVIDER=
# 示例（用通义千问 DashScope 兼容模式 + qwen3.7-plus，评委开箱即用）：
# AI_USER_DEFAULT_PROVIDER=openai
# AI_USER_DEFAULT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# AI_USER_DEFAULT_MODEL=qwen3.7-plus
# AI_USER_DEFAULT_INTAKE_MODEL=qwen3.7-plus
# AI_USER_DEFAULT_API_KEY=replace-with-your-dashscope-key

# ── Auth audit log (fail2ban) ─────────────────────────────
AUDIT_LOG_ENABLED=true
# AUDIT_LOG_PATH=/var/log/plainlist/auth-audit.log
# TRUST_PROXY=true

# ── CORS（移动端 App 需要）──────────────────────────────────
# Capacitor 来源已自动允许，这里可添加额外的前端域名（逗号分隔）
# CORS_ORIGINS=https://app.example.com,https://staging.example.com

# MiniMax M3（OpenAI 兼容，推荐）：
# AI_PROVIDER=openai
# AI_REVIEW_BASE_URL=https://api.minimaxi.com/v1
# AI_REVIEW_MODEL=MiniMax-M3
# AI_REVIEW_API_KEY=sk-cp-...
# AI_REVIEW_TIMEOUT_MS=180000

# MiniMax M3（Anthropic 兼容）：
# AI_PROVIDER=anthropic
# AI_REVIEW_BASE_URL=https://api.minimax.chat/anthropic
# AI_REVIEW_MODEL=MiniMax-M3
# AI_REVIEW_API_KEY=sk-cp-...
# AI_REVIEW_TIMEOUT_MS=180000
