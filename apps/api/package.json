{
  "name": "@plainlist/api",
  "version": "2.0.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "predev": "npm run build -w @plainlist/shared",
    "dev": "tsx watch src/server.ts",
    "prebuild": "npm run build -w @plainlist/shared",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest run src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@plainlist/shared": "*",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.15.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "tsx": "^4.20.6"
  }
}
